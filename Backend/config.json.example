{
  "server": {
    "host": "0.0.0.0",
    "port": 8082,
    "threads": 4,
    "log_level": "info"
  },
  "database": {
    "host": "mysql",
    "port": 33060,
    "ssl": false,
    "username": "app",
    "password": "CHANGE_ME",
    "database": "image_generator",
    "pool_size": 10,
    "charset": "utf8mb4"
  },
  "jwt": {
    "secret": "CHANGE_ME",
    "expiration_hours": 24
  },
  "python_service": {
    "url": "http://model-service:8081",
    "timeout_seconds": 900
  },
  "task_engine": {
    "workers": 2,
    "poll_interval_ms": 500,
    "lease_seconds": 900,
    "max_retries": 3,
    "worker_prefix": "backend-worker"
  },
  "cors": {
    "enabled": true,
    "allow_origins": ["http://localhost:3000"],
    "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "allow_headers": ["Content-Type", "Authorization"]
  },
  "minio": {
    "endpoint": "http://127.0.0.1:9000",
    "access_key": "minioadmin",
    "secret_key": "minioadmin",
    "bucket": "zimage",
    "region": "us-east-1",
    "presign_expiry_seconds": 3600
  },
  "storage": {
    "root_dir": "/app/storage/images",
    "public_url_prefix": "/api/images",
    "extension": "png"
  },
  "redis": {
    "host": "127.0.0.1",
    "port": 6379,
    "password": "",
    "db": 0,
    "pool_size": 4,
    "connect_timeout_ms": 1000,
    "socket_timeout_ms": 5000,
    "task_queue_key": "zimage:task_queue",
    "lease_key_prefix": "zimage:lease:",
    "enabled": true
  },
  "cache": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 6379,
    "password": "",
    "db": 1,
    "pool_size": 4,
    "connect_timeout_ms": 1000,
    "socket_timeout_ms": 500,
    "key_prefix": "zimage:",
    "version_key_ttl_seconds": 86400
  }
}
