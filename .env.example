MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
MYSQL_SQL_HOST_PORT=3306
MYSQL_X_HOST_PORT=33060
FRONTEND_PORT=80

BACKEND_PORT=8080
BACKEND_THREADS=4

DB_HOST=mysql
DB_PORT=33060
DB_USERNAME=app
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=image_generator

JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRATION_HOURS=24

PYTHON_SERVICE_URL=http://model-service:8081
PYTHON_SERVICE_TIMEOUT_SECONDS=360

TASK_ENGINE_WORKERS=2
TASK_ENGINE_POLL_INTERVAL_MS=500
TASK_ENGINE_LEASE_SECONDS=600
TASK_ENGINE_MAX_RETRIES=3
TASK_ENGINE_WORKER_PREFIX=backend-worker

STORAGE_ROOT_DIR=/app/storage/images
STORAGE_PUBLIC_URL_PREFIX=/api/images
STORAGE_EXTENSION=png

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=zimage
REDIS_HOST_PORT=6379
REDIS_ENABLED=true
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_POOL_SIZE=4
REDIS_CONNECT_TIMEOUT_MS=1000
REDIS_SOCKET_TIMEOUT_MS=5000
REDIS_TASK_QUEUE_KEY=zimage:task_queue
REDIS_LEASE_KEY_PREFIX=zimage:lease:

CACHE_ENABLED=true
CACHE_HOST=redis
CACHE_PORT=6379
CACHE_PASSWORD=CHANGE_ME_REDIS_PASSWORD
CACHE_DB=1
CACHE_POOL_SIZE=4
CACHE_CONNECT_TIMEOUT_MS=1000
CACHE_SOCKET_TIMEOUT_MS=500
CACHE_KEY_PREFIX=zimage:
CACHE_VERSION_KEY_TTL_SECONDS=86400

MODEL_SERVICE_PORT=8081
MODEL_PATH=/app/models/Z-Image-Turbo
MODEL_SERVICE_ALLOW_ORIGINS=*
MODEL_SERVICE_LOG_DIR=/app/logs
MODEL_SERVICE_TEMP_DIR=/app/temp
MODEL_SERVICE_MAX_CONCURRENT_GENERATIONS=1
MODEL_SERVICE_TEMP_FILE_MAX_AGE_HOURS=24
MODEL_SERVICE_TEMP_FILE_CLEANUP_INTERVAL_SECONDS=3600

VITE_BACKEND_PROXY_TARGET=http://backend:8080
VITE_HEALTH_PROXY_TARGET=http://backend:8080
